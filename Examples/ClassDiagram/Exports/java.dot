digraph UML {
  rankdir=TB;
  bgcolor="white";
  compound=true;
  fontname="Helvetica";
  fontsize=12;
  node [shape=none margin=0 fontname="Helvetica" fontsize=12];
  edge [fontname="Helvetica" fontsize=10];
  "medialibrary.Genre" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="#f5f5f5" COLOR="#333333"><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="10" COLOR="#333333">&lt;&lt;enumeration&gt;&gt;</FONT><BR/><B><FONT COLOR="#333333">Genre</FONT></B></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333"> </FONT></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333"> </FONT></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">POP</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">ROCK</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">JAZZ</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">CLASSICAL</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">ELECTRONIC</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">SPOKEN_WORD</FONT><BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  "medialibrary.Library" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="#f5f5f5" COLOR="#333333"><TR><TD ALIGN="CENTER"><B><FONT COLOR="#333333">Library</FONT></B></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">- playlists: List&lt;Playlist&gt;</FONT><BR ALIGN="LEFT"/></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">+ Library(playlists: List&lt;Playlist&gt;)</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">+ playlists(): List&lt;Playlist&gt;</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">+ addPlaylist(playlist: Playlist): void</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">+ playlist(named: String): Playlist</FONT><BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  "medialibrary.MediaItem" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="#f5f5f5" COLOR="#333333"><TR><TD ALIGN="CENTER"><B><FONT COLOR="#333333">MediaItem</FONT></B></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">- title: String</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">- duration: double</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">- genre: Genre</FONT><BR ALIGN="LEFT"/></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">+ MediaItem(title: String, duration: double, genre: Genre)</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">+ title(): String</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">+ duration(): double</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">+ genre(): Genre</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">+ play(): void</FONT><BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  "medialibrary.Playable" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="#f5f5f5" COLOR="#333333"><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="10" COLOR="#333333">&lt;&lt;interface&gt;&gt;</FONT><BR/><B><FONT COLOR="#333333">Playable</FONT></B></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333"> </FONT></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">title(): String</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">duration(): double</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">play(): void</FONT><BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  "medialibrary.Player" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="#f5f5f5" COLOR="#333333"><TR><TD ALIGN="CENTER"><B><FONT COLOR="#333333">Player</FONT></B></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">- library: Library</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">- nowPlaying: Playable</FONT><BR ALIGN="LEFT"/></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">+ Player(library: Library)</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">+ nowPlaying(): Playable</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">+ play(item: Playable): void</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">+ playFirstItem(playlistNamed: String): void</FONT><BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  "medialibrary.Playlist" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="#f5f5f5" COLOR="#333333"><TR><TD ALIGN="CENTER"><B><FONT COLOR="#333333">Playlist</FONT></B></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">- name: String</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">- items: List&lt;MediaItem&gt;</FONT><BR ALIGN="LEFT"/></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">+ Playlist(name: String, items: List&lt;MediaItem&gt;)</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">+ name(): String</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">+ items(): List&lt;MediaItem&gt;</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">+ totalDuration(): double</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">+ add(item: MediaItem): void</FONT><BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  "medialibrary.Podcast" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="#f5f5f5" COLOR="#333333"><TR><TD ALIGN="CENTER"><B><FONT COLOR="#333333">Podcast</FONT></B></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">- host: String</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">- episodeNumber: int</FONT><BR ALIGN="LEFT"/></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">+ Podcast(title: String, duration: double, host: String, episodeNumber: int)</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">+ play(): void</FONT><BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  "medialibrary.Song" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="#f5f5f5" COLOR="#333333"><TR><TD ALIGN="CENTER"><B><FONT COLOR="#333333">Song</FONT></B></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">- artist: String</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">- album: String</FONT><BR ALIGN="LEFT"/></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">+ Song(title: String, duration: double, genre: Genre, artist: String, album: String)</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">+ play(): void</FONT><BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  "medialibrary.MediaItem" -> "medialibrary.Playable" [arrowhead=empty style=dashed color="#666666"];
  "medialibrary.Podcast" -> "medialibrary.MediaItem" [arrowhead=empty style=solid color="#666666"];
  "medialibrary.Song" -> "medialibrary.MediaItem" [arrowhead=empty style=solid color="#666666"];
  "medialibrary.Library" -> "medialibrary.Playlist" [dir=back arrowtail=odiamond color="#666666" label="playlists" headlabel="*"];
  "medialibrary.MediaItem" -> "medialibrary.Genre" [dir=back arrowtail=diamond color="#666666" label="genre" headlabel="1"];
  "medialibrary.Player" -> "medialibrary.Library" [dir=back arrowtail=diamond color="#666666" label="library" headlabel="1"];
  "medialibrary.Player" -> "medialibrary.Playable" [dir=back arrowtail=diamond color="#666666" label="nowPlaying" headlabel="1"];
  "medialibrary.Playlist" -> "medialibrary.MediaItem" [dir=back arrowtail=odiamond color="#666666" label="items" headlabel="*"];
  "medialibrary.Song" -> "medialibrary.Genre" [arrowhead=vee style=dashed color="#666666"];
}
