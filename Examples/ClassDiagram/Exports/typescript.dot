digraph UML {
  rankdir=TB;
  bgcolor="white";
  compound=true;
  fontname="Helvetica";
  fontsize=12;
  node [shape=none margin=0 fontname="Helvetica" fontsize=12];
  edge [fontname="Helvetica" fontsize=10];
  "Library" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="#f5f5f5" COLOR="#333333"><TR><TD ALIGN="CENTER"><B><FONT COLOR="#333333">Library</FONT></B></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">playlists: Playlist[]</FONT><BR ALIGN="LEFT"/></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">constructor(playlists: Playlist[])</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">addPlaylist(playlist: Playlist): void</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">playlist(named: string): Playlist | undefined</FONT><BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  "MediaItem" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="#f5f5f5" COLOR="#333333"><TR><TD ALIGN="CENTER"><B><FONT COLOR="#333333">MediaItem</FONT></B></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">title: string</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">duration: number</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">genre: Genre</FONT><BR ALIGN="LEFT"/></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">constructor(title: string, duration: number, genre: Genre)</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">play(): void</FONT><BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  "Playable" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="#f5f5f5" COLOR="#333333"><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="10" COLOR="#333333">&lt;&lt;interface&gt;&gt;</FONT><BR/><B><FONT COLOR="#333333">Playable</FONT></B></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">title: string</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">duration: number</FONT><BR ALIGN="LEFT"/></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">play(): void</FONT><BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  "Genre" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="#f5f5f5" COLOR="#333333"><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="10" COLOR="#333333">&lt;&lt;enumeration&gt;&gt;</FONT><BR/><B><FONT COLOR="#333333">Genre</FONT></B></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333"> </FONT></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333"> </FONT></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">Pop</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">Rock</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">Jazz</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">Classical</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">Electronic</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">SpokenWord</FONT><BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  "Player" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="#f5f5f5" COLOR="#333333"><TR><TD ALIGN="CENTER"><B><FONT COLOR="#333333">Player</FONT></B></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">- nowPlaying: Playable | null</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">- library: Library</FONT><BR ALIGN="LEFT"/></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">constructor(library: Library)</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">play(item: Playable): void</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">playFirstItem(playlistNamed: string): void</FONT><BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  "Playlist" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="#f5f5f5" COLOR="#333333"><TR><TD ALIGN="CENTER"><B><FONT COLOR="#333333">Playlist</FONT></B></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">name: string</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">items: MediaItem[]</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">totalDuration: number</FONT><BR ALIGN="LEFT"/></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">constructor(name: string, items: MediaItem[])</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">add(item: MediaItem): void</FONT><BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  "Podcast" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="#f5f5f5" COLOR="#333333"><TR><TD ALIGN="CENTER"><B><FONT COLOR="#333333">Podcast</FONT></B></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">host: string</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">episodeNumber: number</FONT><BR ALIGN="LEFT"/></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">constructor(title: string, duration: number, host: string, episodeNumber: number)</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">play(): void</FONT><BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  "Song" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="#f5f5f5" COLOR="#333333"><TR><TD ALIGN="CENTER"><B><FONT COLOR="#333333">Song</FONT></B></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">artist: string</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">album: string</FONT><BR ALIGN="LEFT"/></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">constructor(title: string, duration: number, genre: Genre, artist: string, album: string?)</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">play(): void</FONT><BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  "MediaItem" -> "Playable" [arrowhead=empty style=dashed color="#666666"];
  "Podcast" -> "MediaItem" [arrowhead=empty style=solid color="#666666"];
  "Song" -> "MediaItem" [arrowhead=empty style=solid color="#666666"];
  "Library" -> "Playlist" [dir=back arrowtail=odiamond color="#666666" label="playlists" headlabel="*"];
  "MediaItem" -> "Genre" [dir=back arrowtail=diamond color="#666666" label="genre" headlabel="1"];
  "Player" -> "Library" [dir=back arrowtail=diamond color="#666666" label="library" headlabel="1"];
  "Player" -> "Playable" [arrowhead=vee style=dashed color="#666666"];
  "Playlist" -> "MediaItem" [dir=back arrowtail=odiamond color="#666666" label="items" headlabel="*"];
  "Song" -> "Genre" [arrowhead=vee style=dashed color="#666666"];
}
