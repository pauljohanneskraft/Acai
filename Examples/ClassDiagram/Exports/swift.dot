digraph UML {
  rankdir=TB;
  bgcolor="white";
  compound=true;
  fontname="Helvetica";
  fontsize=12;
  node [shape=none margin=0 fontname="Helvetica" fontsize=12];
  edge [fontname="Helvetica" fontsize=10];
  "Library" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="#f5f5f5" COLOR="#333333"><TR><TD ALIGN="CENTER"><B><FONT COLOR="#333333">Library</FONT></B></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">+ playlists: Array&lt;Playlist&gt;</FONT><BR ALIGN="LEFT"/></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">+ init(playlists: Array&lt;Playlist&gt;)</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">+ addPlaylist(playlist: Playlist)</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">+ playlist(name: String): Playlist?</FONT><BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  "MediaItem" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="#f5f5f5" COLOR="#333333"><TR><TD ALIGN="CENTER"><B><FONT COLOR="#333333">MediaItem</FONT></B></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">+ title: String</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">+ duration: TimeInterval</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">+ genre: Genre</FONT><BR ALIGN="LEFT"/></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">+ init(title: String, duration: TimeInterval, genre: Genre)</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">+ play()</FONT><BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  "Playable" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="#f5f5f5" COLOR="#333333"><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="10" COLOR="#333333">&lt;&lt;interface&gt;&gt;</FONT><BR/><B><FONT COLOR="#333333">Playable</FONT></B></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">+ title: String</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">+ duration: TimeInterval</FONT><BR ALIGN="LEFT"/></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">+ play()</FONT><BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  "Genre" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="#f5f5f5" COLOR="#333333"><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="10" COLOR="#333333">&lt;&lt;enumeration&gt;&gt;</FONT><BR/><B><FONT COLOR="#333333">Genre</FONT></B></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333"> </FONT></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333"> </FONT></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">pop</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">rock</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">jazz</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">classical</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">electronic</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">spokenWord</FONT><BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  "Player" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="#f5f5f5" COLOR="#333333"><TR><TD ALIGN="CENTER"><B><FONT COLOR="#333333">Player</FONT></B></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">- library: Library</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">+ nowPlaying: Playable?</FONT><BR ALIGN="LEFT"/></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">+ init(library: Library)</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">+ play(item: Playable)</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">+ playFirstItem(name: String)</FONT><BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  "Playlist" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="#f5f5f5" COLOR="#333333"><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="10" COLOR="#333333">&lt;&lt;struct&gt;&gt;</FONT><BR/><B><FONT COLOR="#333333">Playlist</FONT></B></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">+ name: String</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">+ items: Array&lt;MediaItem&gt;</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">+ totalDuration: TimeInterval</FONT><BR ALIGN="LEFT"/></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">+ init(name: String, items: Array&lt;MediaItem&gt;)</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">+ add(item: MediaItem)</FONT><BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  "Podcast" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="#f5f5f5" COLOR="#333333"><TR><TD ALIGN="CENTER"><B><FONT COLOR="#333333">Podcast</FONT></B></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">+ host: String</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">+ episodeNumber: Int</FONT><BR ALIGN="LEFT"/></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">+ init(title: String, duration: TimeInterval, host: String, episodeNumber: Int)</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">+ play()</FONT><BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  "Song" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" BGCOLOR="#f5f5f5" COLOR="#333333"><TR><TD ALIGN="CENTER"><B><FONT COLOR="#333333">Song</FONT></B></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">+ artist: String</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">+ album: String?</FONT><BR ALIGN="LEFT"/></TD></TR><HR/><TR><TD ALIGN="LEFT"><FONT COLOR="#333333">+ init(title: String, duration: TimeInterval, genre: Genre, artist: String, album: String?)</FONT><BR ALIGN="LEFT"/><FONT COLOR="#333333">+ play()</FONT><BR ALIGN="LEFT"/></TD></TR></TABLE>>];
  "MediaItem" -> "Playable" [arrowhead=empty style=dashed color="#666666"];
  "Podcast" -> "MediaItem" [arrowhead=empty style=solid color="#666666"];
  "Song" -> "MediaItem" [arrowhead=empty style=solid color="#666666"];
  "Library" -> "Playlist" [dir=back arrowtail=odiamond color="#666666" label="playlists" headlabel="*"];
  "MediaItem" -> "Genre" [dir=back arrowtail=diamond color="#666666" label="genre" headlabel="1"];
  "Player" -> "Library" [dir=back arrowtail=diamond color="#666666" label="library" headlabel="1"];
  "Player" -> "Playable" [dir=back arrowtail=diamond color="#666666" label="nowPlaying" headlabel="1"];
  "Playlist" -> "MediaItem" [dir=back arrowtail=odiamond color="#666666" label="items" headlabel="*"];
  "Song" -> "Genre" [arrowhead=vee style=dashed color="#666666"];
}
