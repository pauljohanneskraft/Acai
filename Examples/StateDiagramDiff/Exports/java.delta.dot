digraph {
  label="Download.state";
  labelloc=t;
  rankdir=TB;
  fontname="Helvetica";
  fontsize=12;
  node [fontname="Helvetica" fontsize=12];
  edge [fontname="Helvetica" fontsize=10];
  "__initial" [shape=circle style=filled fillcolor="black" width=0.3 label=""];
  "state_IDLE" [shape=Mrecord label="IDLE"];
  "state_REQUESTED" [shape=Mrecord label="REQUESTED"];
  "state_DOWNLOADING" [shape=Mrecord label="DOWNLOADING"];
  "state_VERIFYING" [shape=Mrecord label="VERIFYING"];
  "state_FINISHED" [shape=Mrecord label="FINISHED"];
  "state_FAILED" [shape=Mrecord label="FAILED"];
  "__initial" -> "state_IDLE";
  "__initial" -> "state_REQUESTED" [label="run()"];
  "state_REQUESTED" -> "state_DOWNLOADING" [label="run()"];
  "state_DOWNLOADING" -> "state_VERIFYING" [color="#2e7d32" label="run()"];
  "state_VERIFYING" -> "state_FINISHED" [color="#2e7d32" label="run()"];
  "__initial" -> "state_FAILED" [label="fail()"];
  "state_DOWNLOADING" -> "state_FINISHED" [color="#c62828" label="run()"];
}
