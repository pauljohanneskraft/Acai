digraph {
  label="place_order()";
  labelloc=t;
  rankdir=TB;
  fontname="Helvetica";
  fontsize=12;
  node [fontname="Helvetica" fontsize=12];
  edge [fontname="Helvetica" fontsize=10];
  // Participants
  "func:place_order_header" [shape=box label="&lt;&lt;control&gt;&gt;\nplace_order"];
  "func:charge_header" [shape=box label="&lt;&lt;control&gt;&gt;\ncharge"];
  "func:log_event_header" [shape=box label="&lt;&lt;control&gt;&gt;\nlog_event"];
  "func:verify_header" [shape=box label="&lt;&lt;control&gt;&gt;\nverify"];
  { rank=same; "func:place_order_header"; "func:charge_header"; "func:log_event_header"; "func:verify_header"; }

  // Lifeline step nodes
  node [shape=none label="" width=0 height=0];
  "func:place_order_step0";
  "func:charge_step0";
  "func:log_event_step0";
  "func:verify_step0";
  { rank=same; "func:place_order_step0"; "func:charge_step0"; "func:log_event_step0"; "func:verify_step0"; }
  "func:place_order_step1";
  "func:charge_step1";
  "func:log_event_step1";
  "func:verify_step1";
  { rank=same; "func:place_order_step1"; "func:charge_step1"; "func:log_event_step1"; "func:verify_step1"; }
  "func:place_order_step2";
  "func:charge_step2";
  "func:log_event_step2";
  "func:verify_step2";
  { rank=same; "func:place_order_step2"; "func:charge_step2"; "func:log_event_step2"; "func:verify_step2"; }
  "func:place_order_step3";
  "func:charge_step3";
  "func:log_event_step3";
  "func:verify_step3";
  { rank=same; "func:place_order_step3"; "func:charge_step3"; "func:log_event_step3"; "func:verify_step3"; }
  "func:place_order_step4";
  "func:charge_step4";
  "func:log_event_step4";
  "func:verify_step4";
  { rank=same; "func:place_order_step4"; "func:charge_step4"; "func:log_event_step4"; "func:verify_step4"; }
  "func:place_order_step5";
  "func:charge_step5";
  "func:log_event_step5";
  "func:verify_step5";
  { rank=same; "func:place_order_step5"; "func:charge_step5"; "func:log_event_step5"; "func:verify_step5"; }

  // Lifelines
  "func:place_order_header" -> "func:place_order_step0" [style=invis];
  "func:place_order_step0" -> "func:place_order_step1" [style=invis];
  "func:place_order_step1" -> "func:place_order_step2" [style=invis];
  "func:place_order_step2" -> "func:place_order_step3" [style=invis];
  "func:place_order_step3" -> "func:place_order_step4" [style=invis];
  "func:place_order_step4" -> "func:place_order_step5" [style=invis];
  "func:charge_header" -> "func:charge_step0" [style=invis];
  "func:charge_step0" -> "func:charge_step1" [style=invis];
  "func:charge_step1" -> "func:charge_step2" [style=invis];
  "func:charge_step2" -> "func:charge_step3" [style=invis];
  "func:charge_step3" -> "func:charge_step4" [style=invis];
  "func:charge_step4" -> "func:charge_step5" [style=invis];
  "func:log_event_header" -> "func:log_event_step0" [style=invis];
  "func:log_event_step0" -> "func:log_event_step1" [style=invis];
  "func:log_event_step1" -> "func:log_event_step2" [style=invis];
  "func:log_event_step2" -> "func:log_event_step3" [style=invis];
  "func:log_event_step3" -> "func:log_event_step4" [style=invis];
  "func:log_event_step4" -> "func:log_event_step5" [style=invis];
  "func:verify_header" -> "func:verify_step0" [style=invis];
  "func:verify_step0" -> "func:verify_step1" [style=invis];
  "func:verify_step1" -> "func:verify_step2" [style=invis];
  "func:verify_step2" -> "func:verify_step3" [style=invis];
  "func:verify_step3" -> "func:verify_step4" [style=invis];
  "func:verify_step4" -> "func:verify_step5" [style=invis];

  // Messages
  node [shape=none label=""];
  "func:place_order_step0" -> "func:charge_step0" [label="charge" arrowhead=normal style=solid];
  "func:charge_step1" -> "func:place_order_step1" [arrowhead=normal style=dashed];
  "func:place_order_step2" -> "func:log_event_step2" [color="#2e7d32" label="log_event" arrowhead=normal style=solid];
  "func:log_event_step3" -> "func:place_order_step3" [color="#2e7d32" arrowhead=normal style=dashed];
  "func:place_order_step4" -> "func:verify_step4" [color="#c62828" label="verify" arrowhead=normal style=solid];
  "func:verify_step5" -> "func:place_order_step5" [color="#c62828" arrowhead=normal style=dashed];
}
