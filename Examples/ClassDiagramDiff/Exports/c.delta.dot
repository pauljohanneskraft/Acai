digraph UML {
  rankdir=TB;
  compound=true;
  fontname="Helvetica";
  fontsize=12;
  node [shape=none margin=0 fontname="Helvetica" fontsize=12];
  edge [fontname="Helvetica" fontsize=10];
  "Account" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4"><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="10">&lt;&lt;struct&gt;&gt;</FONT><BR/><B>Account</B></TD></TR><HR/><TR><TD ALIGN="LEFT">+ balance: int<BR ALIGN="LEFT"/></TD></TR><HR/><TR><TD ALIGN="LEFT"> </TD></TR></TABLE>>];
  "LegacyAudit" [label=<<TABLE BORDER="2" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" COLOR="#c62828"><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="10">&lt;&lt;struct&gt;&gt;</FONT><BR/><B>LegacyAudit</B></TD></TR><HR/><TR><TD ALIGN="LEFT">+ code: int<BR ALIGN="LEFT"/></TD></TR><HR/><TR><TD ALIGN="LEFT"> </TD></TR></TABLE>>];
  "OrderService" [label=<<TABLE BORDER="2" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" COLOR="#f9a825"><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="10">&lt;&lt;struct&gt;&gt;</FONT><BR/><B>OrderService</B></TD></TR><HR/><TR><TD ALIGN="LEFT">+ gateway: PaymentGateway<BR ALIGN="LEFT"/></TD></TR><HR/><TR><TD ALIGN="LEFT"> </TD></TR></TABLE>>];
  "PaymentGateway" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4"><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="10">&lt;&lt;struct&gt;&gt;</FONT><BR/><B>PaymentGateway</B></TD></TR><HR/><TR><TD ALIGN="LEFT">+ id: int<BR ALIGN="LEFT"/></TD></TR><HR/><TR><TD ALIGN="LEFT"> </TD></TR></TABLE>>];
  "Receipt" [label=<<TABLE BORDER="2" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4" COLOR="#2e7d32"><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="10">&lt;&lt;struct&gt;&gt;</FONT><BR/><B>Receipt</B></TD></TR><HR/><TR><TD ALIGN="LEFT">+ total: int<BR ALIGN="LEFT"/></TD></TR><HR/><TR><TD ALIGN="LEFT"> </TD></TR></TABLE>>];
  "OrderService" -> "Account" [dir=back arrowtail=diamond color="#c62828" label="account" headlabel="1"];
  "OrderService" -> "PaymentGateway" [dir=back arrowtail=diamond color="#2e7d32" label="gateway" headlabel="1"];
}
